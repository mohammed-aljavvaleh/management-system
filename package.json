    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.11.0",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
