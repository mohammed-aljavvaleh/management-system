# Database
DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"

# Session
SESSION_SECRET="your-secure-random-session-secret-here"

# Optional: Force secure cookies (set to "true" for HTTPS-only)
SESSION_COOKIE_SECURE="true"

# Optional: Your deployed site URL (used for cookie security)
NEXT_PUBLIC_SITE_URL="https://your-app-name.vercel.app"

# Admin creation script only; do not commit real values.
ADMIN_SALON_NAME="Example Salon"
ADMIN_CURRENCY="TRY"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-long-random-password"

# Optional seed override; defaults to TRY.
SEED_SALON_CURRENCY="TRY"
