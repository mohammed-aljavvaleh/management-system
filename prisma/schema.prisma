// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  output     = "../app/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  name         String
  phone        String        @unique
  notes        String?
  appointments Appointment[]
  packages     UserPackage[]
}

model Service {
  id           String        @id @default(cuid())
  name         String        // e.g., "Manicure"
  price        Float
  duration     Int           // duration in minutes
  appointments Appointment[]
  packages    UserPackage[]
}

model Staff {
  id           String        @id @default(cuid())
  name         String
  role         String        @default("Technician")
  appointments Appointment[]
}

model UserPackage {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  name              String

  totalSessions     Int
  remainingSessions Int

  totalPrice        Float
  paidAmount        Float         @default(0)

  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id])

  serviceId         String?
  service           Service?      @relation(fields: [serviceId], references: [id])

  appointments      Appointment[]
  installments      Installment[]
}

model Installment {
  id            String      @id @default(cuid())
  paidAt        DateTime    @default(now())
  amount        Float
  note          String?

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id])
}

model Appointment {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  startTime      DateTime
   
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id]) 
     
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id])
  priceAtBooking Float
  
  staffId        String
  staff          Staff    @relation(fields: [staffId], references: [id])
  
  userPackageId  String?
  userPackage    UserPackage? @relation(fields: [userPackageId], references: [id])

  notes         String?

  status         String   @default("SCHEDULED") // SCHEDULED, CANCELLED, COMPLETED
}