// prisma/schema.prisma
// Multi-tenant schema: every data model is scoped to a Salon.
// Prisma 7 — datasource URL is managed via prisma.config.ts (do NOT add `url` here).

generator client {
  provider   = "prisma-client-js"
  output     = "../app/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── Tenancy Root ────────────────────────────────────────────────────────────

model Salon {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  name         String
  currency     String        @default("TRY")

  admins       Admin[]
  customers    Customer[]
  services     Service[]
  staff        Staff[]
  appointments Appointment[]
  userPackages UserPackage[]
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String

  salonId      String
  salon        Salon    @relation(fields: [salonId], references: [id])
}

// ─── Business Models (all scoped to a Salon) ─────────────────────────────────

model Customer {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  name         String
  phone        String
  notes        String?

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id])

  appointments Appointment[]
  packages     UserPackage[]

  // Phone must be unique *within* a salon, not globally.
  @@unique([salonId, phone])
}

model Service {
  id           String        @id @default(cuid())
  name         String
  price        Float
  duration     Int           // minutes

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id])

  appointments Appointment[]
  packages     UserPackage[]
}

model Staff {
  id           String        @id @default(cuid())
  name         String
  role         String        @default("Technician")

  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id])

  appointments Appointment[]
}

model UserPackage {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  name              String

  totalSessions     Int
  remainingSessions Int

  totalPrice        Float
  paidAmount        Float         @default(0)

  salonId           String
  salon             Salon         @relation(fields: [salonId], references: [id])

  customerId        String
  customer          Customer      @relation(fields: [customerId], references: [id])

  serviceId         String?
  service           Service?      @relation(fields: [serviceId], references: [id])

  appointments      Appointment[]
  installments      Installment[]
}

model Installment {
  id            String      @id @default(cuid())
  paidAt        DateTime    @default(now())
  amount        Float
  note          String?

  userPackageId String
  userPackage   UserPackage @relation(fields: [userPackageId], references: [id])
}

model Appointment {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  startTime      DateTime

  salonId        String
  salon          Salon       @relation(fields: [salonId], references: [id])

  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])

  serviceId      String
  service        Service     @relation(fields: [serviceId], references: [id])
  priceAtBooking Float

  staffId        String
  staff          Staff       @relation(fields: [staffId], references: [id])

  userPackageId  String?
  userPackage    UserPackage? @relation(fields: [userPackageId], references: [id])

  notes          String?
  status         String      @default("SCHEDULED") // SCHEDULED | CANCELLED | COMPLETED
}